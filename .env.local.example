# ============================================================
# Brit Mashiach - Variáveis de Ambiente
# Copiar para .env.local e preencher com os valores reais
# NUNCA commitar o arquivo .env.local no git
# ============================================================

# ---- Supabase -----------------------------------------------
# Obtidas em: supabase.com > seu projeto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Usar apenas em server-side (webhook, admin)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- Stripe -------------------------------------------------
# Obtidas em: stripe.com > Developers > API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
# Criada em: stripe.com > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# ID do preço criado para a assinatura Premium (R$ 47/mês)
STRIPE_PRICE_ID_PREMIUM=price_xxxxxxxxxxxx

# ---- Aplicação ----------------------------------------------
# Em desenvolvimento: http://localhost:3000
# Em produção: https://seu-dominio.com (usado no link do e-mail de confirmação → /auth)
# Supabase → Authentication → URL Configuration → Redirect URLs:
#   https://seu-dominio.com/auth/callback
#   https://seu-dominio.com/auth/callback*   (permite ?next=/profile no link do e-mail)
NEXT_PUBLIC_APP_URL=http://localhost:3000
