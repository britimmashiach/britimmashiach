# ============================================================
# Brit Mashiach - Variáveis de Ambiente
# Copiar para .env.local e preencher com os valores reais
# NUNCA commitar o arquivo .env.local no git
# ============================================================

# ---- Supabase -----------------------------------------------
# Obtidas em: supabase.com > seu projeto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Usar apenas em server-side (webhook Stripe, página /admin — promoção de roles)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- Stripe -------------------------------------------------
# Obtidas em: stripe.com > Developers > API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
# Criada em: stripe.com > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# ID do preço criado para a assinatura Premium (R$ 47/mês)
STRIPE_PRICE_ID_PREMIUM=price_xxxxxxxxxxxx

# ---- Aplicação ----------------------------------------------
# Em desenvolvimento: http://localhost:3000
# Em produção (domínio canónico do site — sitemap, canonical, OG, links Stripe/auth):
#   https://britimmashiach.com
# Supabase → Authentication → URL Configuration → Redirect URLs:
#   https://britimmashiach.com/auth/callback
#   https://britimmashiach.com/auth/callback*   (permite ?next=/profile no link do e-mail)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Calendário / sedrá ------------------------------------
# Lista opcional: slugs do registro de Parashot (ex.: bereshit,noach) com estudo
# publicado em `/studies/{slug}-pardes`. Seeds em `PLACEHOLDER_STUDIES` já entram
# automaticamente; use isto quando houver apenas no Supabase, sem atualizar seeds.
# NEXT_PUBLIC_PUBLISHED_PARSHA_STUDY_SLUGS=noach,vayera
